{
  "name": "@accidentally-awesome-labs/spatula-queue",
  "version": "0.1.1",
  "description": "Internal Spatula BullMQ queue + workers + webhook delivery — NO TS-API compat guarantee. Public SDK is @accidentally-awesome-labs/spatula-client. See docs/compat-policy.md.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/accidentally-awesome-labs/spatula.git",
    "directory": "packages/queue"
  },
  "homepage": "https://github.com/accidentally-awesome-labs/spatula#readme",
  "bugs": {
    "url": "https://github.com/accidentally-awesome-labs/spatula/issues"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "!dist/.tsbuildinfo",
    "!dist/**/*.test.*",
    "!dist/**/__tests__/**"
  ],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run --passWithNoTests",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "clean": "rm -rf dist .turbo *.tsbuildinfo",
    "start:workers": "node --env-file-if-exists=../../.env dist/worker-entrypoint.js"
  },
  "dependencies": {
    "@opentelemetry/api": "^1.9.1",
    "@accidentally-awesome-labs/spatula-core": "workspace:*",
    "@accidentally-awesome-labs/spatula-db": "workspace:*",
    "@accidentally-awesome-labs/spatula-shared": "workspace:*",
    "bullmq": "^5.80.2",
    "drizzle-orm": "^0.45.2",
    "ioredis": "^5.10.0"
  },
  "devDependencies": {
    "@types/pg": "^8.18.0",
    "typescript": "^5.7.0",
    "vitest": "^3.2.6"
  }
}
