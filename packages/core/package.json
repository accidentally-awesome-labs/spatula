{
  "name": "@spatula/core",
  "version": "0.0.1",
  "description": "Core types, interfaces, and pipeline logic for Spatula",
  "license": "MIT",
  "repository": { "type": "git", "url": "https://github.com/spatulaai/spatula.git", "directory": "packages/core" },
  "homepage": "https://github.com/spatulaai/spatula#readme",
  "bugs": { "url": "https://github.com/spatulaai/spatula/issues" },
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./pipeline/types.js": {
      "types": "./dist/pipeline/types.d.ts",
      "import": "./dist/pipeline/types.js"
    },
    "./crawlers/completion-checker.js": {
      "types": "./dist/crawlers/completion-checker.d.ts",
      "import": "./dist/crawlers/completion-checker.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1019.0",
    "@aws-sdk/s3-request-presigner": "^3.1019.0",
    "@duckdb/node-api": "1.5.0-r.1",
    "@mendable/firecrawl-js": "^4.15.4",
    "@spatula/shared": "workspace:*",
    "better-sqlite3": "^12.8.0",
    "cheerio": "^1.2.0",
    "hyparquet": "^1.25.1",
    "hyparquet-writer": "^0.13.0",
    "playwright": "^1.58.2",
    "robots-parser": "^3.0.1",
    "yaml": "^2.8.3",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  }
}
