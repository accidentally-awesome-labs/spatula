{
  "name": "@accidentally-awesome-labs/spatula-core",
  "version": "0.1.1",
  "description": "Internal Spatula core orchestrators — NO TS-API compat guarantee. Public SDK is @accidentally-awesome-labs/spatula-client. See docs/compat-policy.md.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/accidentally-awesome-labs/spatula.git",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/accidentally-awesome-labs/spatula#readme",
  "bugs": {
    "url": "https://github.com/accidentally-awesome-labs/spatula/issues"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./pipeline/types.js": {
      "types": "./dist/pipeline/types.d.ts",
      "import": "./dist/pipeline/types.js"
    },
    "./crawlers/completion-checker.js": {
      "types": "./dist/crawlers/completion-checker.d.ts",
      "import": "./dist/crawlers/completion-checker.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "!dist/.tsbuildinfo",
    "!dist/**/*.test.*",
    "!dist/**/__tests__/**"
  ],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "test:adversarial": "vitest run src/extraction/__tests__/adversarial.test.ts",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .turbo *.tsbuildinfo"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1085.0",
    "@aws-sdk/s3-request-presigner": "^3.1085.0",
    "@duckdb/node-api": "1.5.0-r.1",
    "@mendable/firecrawl-js": "^4.30.0",
    "@accidentally-awesome-labs/spatula-core-types": "workspace:*",
    "@accidentally-awesome-labs/spatula-shared": "workspace:*",
    "better-sqlite3": "^12.8.0",
    "cheerio": "^1.2.0",
    "hyparquet": "^1.25.1",
    "hyparquet-writer": "^0.13.0",
    "playwright": "^1.61.1",
    "robots-parser": "^3.0.1",
    "yaml": "^2.8.3",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "typescript": "^5.7.0",
    "vitest": "^3.2.6"
  }
}
