{
  "name": "@spatula/client",
  "version": "0.1.0",
  "description": "Spatula API client — TypeScript SDK for the Spatula REST API. ESM-only, browser+Node compatible, fetch-based.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/accidentally-awesome-labs/spatula.git",
    "directory": "packages/client"
  },
  "homepage": "https://github.com/accidentally-awesome-labs/spatula#readme",
  "bugs": {
    "url": "https://github.com/accidentally-awesome-labs/spatula/issues"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "engines": {
    "node": ">=22"
  },
  "sideEffects": false,
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "dependencies": {
    "eventsource": "4.1.0"
  },
  "peerDependencies": {
    "@spatula/core-types": "0.1.0"
  },
  "devDependencies": {
    "@size-limit/esbuild": "^12.1.0",
    "@size-limit/preset-small-lib": "^12.1.0",
    "@spatula/core-types": "workspace:*",
    "@spatula/shared": "workspace:*",
    "@types/node": "^22.0.0",
    "size-limit": "^12.1.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0",
    "zod": "^3.24.0"
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "typecheck": "tsc --noEmit",
    "size": "size-limit",
    "gen:errors": "tsx scripts/gen-error-classes.ts",
    "clean": "rm -rf dist .turbo"
  },
  "size-limit": [
    {
      "name": "core client surface",
      "path": "dist/index.js",
      "import": "{ SpatulaClient, createJob, listJobs, getEntities }",
      "limit": "50 kB",
      "gzip": true,
      "config": "./size-limit.esbuild.config.js"
    }
  ]
}
