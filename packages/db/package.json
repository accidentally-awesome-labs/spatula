{
  "name": "@accidentally-awesome-labs/spatula-db",
  "version": "0.1.1",
  "description": "Internal Spatula PostgreSQL + SQLite database layer — NO TS-API compat guarantee. Public SDK is @accidentally-awesome-labs/spatula-client. See docs/compat-policy.md.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/accidentally-awesome-labs/spatula.git",
    "directory": "packages/db"
  },
  "homepage": "https://github.com/accidentally-awesome-labs/spatula#readme",
  "bugs": {
    "url": "https://github.com/accidentally-awesome-labs/spatula/issues"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "drizzle",
    "drizzle-sqlite",
    "README.md",
    "LICENSE",
    "!dist/.tsbuildinfo",
    "!dist/**/*.test.*",
    "!dist/**/__tests__/**"
  ],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run --passWithNoTests",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "clean": "rm -rf dist .turbo *.tsbuildinfo",
    "db:generate": "drizzle-kit generate",
    "db:generate:sqlite": "drizzle-kit generate --config drizzle.config.sqlite.ts",
    "db:migrate": "node --env-file-if-exists=../../.env --import tsx src/run-migrate.ts"
  },
  "dependencies": {
    "@accidentally-awesome-labs/spatula-core": "workspace:*",
    "@accidentally-awesome-labs/spatula-shared": "workspace:*",
    "better-sqlite3": "^12.8.0",
    "drizzle-orm": "^0.45.2",
    "ioredis": "^5.10.0",
    "pg": "^8.20.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/pg": "^8.18.0",
    "drizzle-kit": "^0.31.10",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.2.6"
  }
}
