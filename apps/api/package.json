{
  "name": "@spatula/api",
  "version": "0.0.1",
  "description": "Internal Spatula Hono REST API server — NO TS-API compat guarantee. Public SDK is @spatula/client. See docs/compat-policy.md.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/accidentally-awesome-labs/spatula.git",
    "directory": "apps/api"
  },
  "homepage": "https://github.com/accidentally-awesome-labs/spatula#readme",
  "bugs": {
    "url": "https://github.com/accidentally-awesome-labs/spatula/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/main.js",
    "dev": "tsx watch src/index.ts",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@bull-board/api": "^6.20.6",
    "@bull-board/hono": "^6.20.6",
    "@bull-board/ui": "^6.20.6",
    "@hono/node-server": "^1.19.11",
    "@hono/node-ws": "^1.3.0",
    "@hono/swagger-ui": "^0.6.1",
    "@hono/zod-openapi": "^0.19.10",
    "ajv": "^8.20.0",
    "ajv-formats": "^3.0.1",
    "@spatula/core": "workspace:*",
    "@spatula/db": "workspace:*",
    "@spatula/queue": "workspace:*",
    "@spatula/shared": "workspace:*",
    "hono": "^4.12.7",
    "ioredis": "^5.10.0",
    "jose": "^6.2.2",
    "yaml": "2.8.3",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^25.3.5",
    "@types/pg": "^8.18.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  }
}
