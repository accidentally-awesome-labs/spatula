# Tier 4 Test Configuration
# Copy to .env.test and fill in your keys

# OpenRouter (for real LLM tests — cheapest model used: google/gemini-2.5-flash)
OPENROUTER_API_KEY=

# Firecrawl (for real crawling tests)
FIRECRAWL_API_KEY=

# Docker Compose ports (optional overrides)
# TEST_POSTGRES_PORT=5433
# TEST_REDIS_PORT=6380
